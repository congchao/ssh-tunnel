{
  "name": "ssh-tunnel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "bash scripts/release.sh",
    "package:mac:arm64": "bash scripts/build-macos-arm64.sh",
    "package:mac:x64": "bash scripts/build-macos-x64.sh",
    "package:win:amd64": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-amd64.ps1",
    "release:mac:x64": "yarn package:mac:x64",
    "release:mac:arm64": "yarn package:mac:arm64",
    "release:windows:x64": "yarn package:win:amd64"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "ant-design-vue": "^4.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "@tauri-apps/cli": "^2"
  }
}
