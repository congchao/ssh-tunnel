{
  "name": "ssh-tunnel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "bash scripts/release.sh",
    "release:mac:x64": "tauri build --target x86_64-apple-darwin --ci",
    "release:mac:arm64": "tauri build --target aarch64-apple-darwin --ci",
    "release:windows:x64": "tauri build --target x86_64-pc-windows-msvc --ci"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "ant-design-vue": "^4.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "@tauri-apps/cli": "^2"
  }
}
